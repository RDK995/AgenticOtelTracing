# Optional tracing providers
ENABLE_OTEL_TRACING=true
ENABLE_LANGSMITH_TRACING=true
ENABLE_LANGFUSE_TRACING=true

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=uk-resell-adk

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Postgres -> Langfuse exporter
LANGFUSE_EXPORT_BATCH_SIZE=200
LANGFUSE_EXPORT_TIMEOUT_SECONDS=20
LANGFUSE_EXPORT_POLL_SECONDS=5
LANGFUSE_EXPORT_LOG_LEVEL=INFO

# Postgres -> Cloud Trace exporter
# Uses ADC by default. Optionally set CLOUD_TRACE_ACCESS_TOKEN directly.
CLOUD_TRACE_OTLP_ENDPOINT=https://telemetry.googleapis.com/v1/traces
CLOUD_TRACE_ACCESS_TOKEN=
CLOUD_TRACE_QUOTA_PROJECT=
CLOUD_TRACE_PROJECT_ID=
CLOUD_TRACE_EXPORT_BATCH_SIZE=200
CLOUD_TRACE_EXPORT_TIMEOUT_SECONDS=20
CLOUD_TRACE_EXPORT_POLL_SECONDS=5
CLOUD_TRACE_EXPORT_LOG_LEVEL=INFO

# Postgres -> Dynatrace exporter
# Example SaaS endpoint:
# https://<environment-id>.live.dynatrace.com/api/v2/otlp/v1/traces
DYNATRACE_OTLP_ENDPOINT=
DYNATRACE_API_TOKEN=
DYNATRACE_EXPORT_BATCH_SIZE=200
DYNATRACE_EXPORT_TIMEOUT_SECONDS=20
DYNATRACE_EXPORT_POLL_SECONDS=5
DYNATRACE_EXPORT_LOG_LEVEL=INFO

# Source selection + depth
ENABLED_SOURCES=hlj,ninningame,surugaya
SOURCE_RESEARCH_DEPTH_MULTIPLIER=6

# Live FX rates (currency conversion to GBP)
ENABLE_LIVE_FX_RATES=true
FX_API_URL=https://api.frankfurter.dev/v1/latest
FX_REFRESH_SECONDS=21600

# Local Postgres (OTel trace warehouse)
POSTGRES_CONTAINER_NAME=otel-postgres
POSTGRES_IMAGE=postgres:16
POSTGRES_PORT=5432
POSTGRES_DB=otel_observability
POSTGRES_USER=otel_user
POSTGRES_PASSWORD=otel_password
POSTGRES_VOLUME=otel-postgres-data

# OTLP -> Postgres ingest service
OTEL_INGEST_HOST=127.0.0.1
OTEL_INGEST_PORT=4318
OTEL_INGEST_TRACES_PATH=/v1/traces
OTEL_POSTGRES_DSN=postgresql://otel_user:otel_password@localhost:5432/otel_observability
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
OTEL_SERVICE_NAME=uk-resell-adk
OTEL_CAPTURE_FUNCTION_ARGS=true
OTEL_CAPTURE_FUNCTION_RESULT=true
OTEL_MAX_ATTR_LEN=4000
